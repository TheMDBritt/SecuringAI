# Model provider: openai | anthropic | axiom (fake/sandbox)
MODEL_PROVIDER=axiom

# OpenAI (if MODEL_PROVIDER=openai)
OPENAI_API_KEY=

# Anthropic (if MODEL_PROVIDER=anthropic)
