# Max tokens budget per session
MAX_TOKENS_PER_SESSION=50000

# Auth (GitHub OAuth — added in M4)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
